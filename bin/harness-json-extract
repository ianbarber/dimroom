#!/usr/bin/env python3
"""
harness-json-extract — shared JSON-path helper for harness flow scripts.

Reads JSON on stdin, walks a small path DSL, prints the addressed value.
Replaces inline `python3 -c` blocks in bin/harness-*-flow.sh so the
extraction idiom lives in one place (see issue #115).

Path DSL:
    - keys separated by '.'          e.g. data.assetCount
    - numeric indices in brackets    e.g. data[0].id
    - '[*]' wildcard to iterate      e.g. data[*].id  (one line per element)
    - keys may contain any character except '.', '[', ']'

Flags:
    --default VAL   If path is missing or resolves to null, print VAL and exit 0.
                    Without this, a missing path exits non-zero with a message.
    --length        Path must resolve to a list; print len(list).
    --iter          Path must resolve to a list; print one element per line.
                    Redundant with '[*]' in the path (either form works).
    --absent        Print 'absent' if the path is missing or null, else 'present'.
    --float         Parse the resolved scalar as float() before printing
                    (so "2" and 2.0 both print as "2.0"). Rejects booleans.
                    JSON numbers don't round-trip through string comparison:
                    Swift's JSONEncoder writes Double(2.0) as `2`, Python parses
                    it as int, and str(2) != "2.0" — hence the float coercion.
    --equals VAL    Epsilon-compare the resolved float against VAL. Exit 0 on
                    hit, exit 1 on miss. Requires --float. Nothing is printed
                    on a successful compare (use shell exit code).
    --epsilon N     Tolerance for --equals. Default 1e-9.

Exit codes:
    0  success (value printed, or --equals hit)
    1  --equals miss (clean compare, no error)
    2  argparse / invalid JSON / usage error
    3  path not found (no --default / --absent to rescue)
    4  type mismatch (e.g. --length on non-list, --float on non-numeric)

Booleans are emitted lowercase ('true' / 'false') to match JSON — callers
that compare against 'True' / 'False' must be updated at the same time.
"""
import argparse
import json
import re
import sys


PATH_TOKEN_RE = re.compile(r'[^.\[\]]+')


def parse_path(path):
    tokens = []
    i = 0
    n = len(path)
    while i < n:
        c = path[i]
        if c == '.':
            i += 1
            continue
        if c == '[':
            end = path.find(']', i)
            if end < 0:
                raise ValueError(f"unterminated '[' in path: {path!r}")
            inner = path[i + 1:end]
            if inner == '*':
                tokens.append(('wildcard',))
            else:
                try:
                    tokens.append(('index', int(inner)))
                except ValueError:
                    raise ValueError(f"bad index {inner!r} in path: {path!r}")
            i = end + 1
            continue
        m = PATH_TOKEN_RE.match(path, i)
        if not m:
            raise ValueError(f"bad path near {path[i:]!r} in {path!r}")
        tokens.append(('key', m.group(0)))
        i = m.end()
    return tokens


def walk(node, tokens):
    """Walk tokens. Returns list of resolved values (length > 1 only if wildcard used)."""
    results = [node]
    for tok in tokens:
        kind = tok[0]
        nxt = []
        for cur in results:
            if kind == 'key':
                key = tok[1]
                if not isinstance(cur, dict) or key not in cur:
                    raise KeyError(f"key {key!r} missing")
                nxt.append(cur[key])
            elif kind == 'index':
                idx = tok[1]
                if not isinstance(cur, list) or idx >= len(cur) or idx < -len(cur):
                    raise KeyError(f"index {idx} out of range")
                nxt.append(cur[idx])
            elif kind == 'wildcard':
                if not isinstance(cur, list):
                    raise KeyError("wildcard '[*]' requires a list")
                nxt.extend(cur)
        results = nxt
    return results


def format_scalar(v):
    if isinstance(v, bool):
        return 'true' if v else 'false'
    if v is None:
        return ''
    return str(v)


def has_wildcard(tokens):
    return any(t[0] == 'wildcard' for t in tokens)


def _emit_float(node, args):
    """Coerce node to float, then either print it or epsilon-compare against
    args.equals. Booleans are rejected (float(True) == 1.0 would silently
    compare against 1.0)."""
    if isinstance(node, bool):
        print(f"harness-json-extract: path {args.path!r} resolved to a boolean, not a number", file=sys.stderr)
        sys.exit(4)
    try:
        actual = float(node)
    except (TypeError, ValueError):
        print(f"harness-json-extract: path {args.path!r} value {node!r} is not numeric", file=sys.stderr)
        sys.exit(4)
    if args.equals is None:
        print(actual)
        return
    try:
        expected = float(args.equals)
    except ValueError:
        print(f"harness-json-extract: --equals value {args.equals!r} is not numeric", file=sys.stderr)
        sys.exit(2)
    if abs(actual - expected) < args.epsilon:
        return
    sys.exit(1)


def main():
    p = argparse.ArgumentParser(add_help=True)
    p.add_argument('path')
    grp = p.add_mutually_exclusive_group()
    grp.add_argument('--length', action='store_true')
    grp.add_argument('--iter', action='store_true', dest='iter_')
    grp.add_argument('--absent', action='store_true')
    p.add_argument('--default', dest='default', default=None)
    p.add_argument('--float', action='store_true', dest='as_float')
    p.add_argument('--equals', dest='equals', default=None)
    p.add_argument('--epsilon', dest='epsilon', type=float, default=1e-9)
    args = p.parse_args()

    if args.equals is not None and not args.as_float:
        print("harness-json-extract: --equals requires --float", file=sys.stderr)
        sys.exit(2)
    if args.as_float and (args.length or args.iter_ or args.absent):
        print("harness-json-extract: --float is incompatible with --length / --iter / --absent", file=sys.stderr)
        sys.exit(2)

    raw = sys.stdin.read()
    try:
        doc = json.loads(raw)
    except json.JSONDecodeError as e:
        print(f"harness-json-extract: invalid JSON on stdin: {e}", file=sys.stderr)
        sys.exit(2)

    try:
        tokens = parse_path(args.path)
    except ValueError as e:
        print(f"harness-json-extract: {e}", file=sys.stderr)
        sys.exit(2)

    wildcard = has_wildcard(tokens)

    if wildcard and args.as_float:
        print("harness-json-extract: --float / --equals are incompatible with '[*]'", file=sys.stderr)
        sys.exit(2)

    try:
        values = walk(doc, tokens)
    except KeyError as e:
        if args.absent:
            print('absent')
            return
        if args.default is not None:
            if args.as_float:
                # --default still wins before the compare; route through the
                # same float / equals path so callers see consistent behaviour.
                _emit_float(args.default, args)
                return
            print(args.default)
            return
        print(f"harness-json-extract: path {args.path!r} not found: {e}", file=sys.stderr)
        sys.exit(3)

    # wildcard always produces a list of results; otherwise values has length 1
    if not wildcard:
        node = values[0]
        if args.absent:
            print('absent' if node is None else 'present')
            return
        if args.length:
            if not isinstance(node, list):
                print(f"harness-json-extract: path {args.path!r} is not a list", file=sys.stderr)
                sys.exit(4)
            print(len(node))
            return
        if args.iter_:
            if not isinstance(node, list):
                print(f"harness-json-extract: path {args.path!r} is not a list", file=sys.stderr)
                sys.exit(4)
            for item in node:
                print(format_scalar(item))
            return
        if node is None and args.default is not None:
            if args.as_float:
                _emit_float(args.default, args)
                return
            print(args.default)
            return
        if args.as_float:
            _emit_float(node, args)
            return
        print(format_scalar(node))
        return

    # wildcard path
    if args.length or args.absent:
        print("harness-json-extract: --length / --absent are incompatible with '[*]'", file=sys.stderr)
        sys.exit(2)
    for v in values:
        print(format_scalar(v))


if __name__ == '__main__':
    main()
